    }
  },
  "mongo": {
    "username": "__PUT_MONGO_USERNAME_HERE__",
    "password": "__PUT_MONGO_PASSWORD_HERE__",
    "url": "127.0.0.1",
    "database": "__PUT_MONGO_DATABASE_HERE__",
    "options": "retryWrites=false&directConnection=true"
  }
}

