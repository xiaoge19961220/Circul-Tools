{
  "name": "find_user_tools",
  "productName": "Circul tools",
  "version": "1.2.0",
  "main": "electron-main/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "release": "node -r dotenv/config ./node_modules/.bin/electron-builder --publish always"
  },
  "dependencies": {
    "fs-extra": "^11.3.3",
    "mongodb": "^7.0.0",
    "tunnel-ssh": "^5.2.0"
  },
  "build": {
    "productName": "Circul tools",
    "appId": "com.circultools.app",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "xiaoge19961220",
        "repo": "tools"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "files": [
      "electron-main/**/*",
      "renderer/**/*",
      "ssh-tunnel/**/*",
      "db/**/*",
      "connection-config/**/*",
      "legacy/**/*",
      "assets/**/*",
      "release/**/*",
      "resources/**/*",
      "preload.js",
      "package.json"
    ]
  },
  "overrides": {
    "nan": "^2.22.0"
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "electron": "^32.0.0",
    "electron-builder": "^26.4.0"
  }
}
